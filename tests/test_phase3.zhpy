# ============================================================
# Phase 3 测试：模块与导入系统
# ============================================================

# --- 测试 1：基本导入中文模块名映射 ---
导入 数学
输出("=== 测试 1: 基本导入 ===")
输出(数学.pi)

# --- 测试 2：导入并使用别名 ---
导入 数学 作为 数学库
输出("=== 测试 2: 导入别名 ===")
输出(数学库.sqrt(16))

# --- 测试 3：从模块导入特定函数 ---
从 数学 导入 平方根
输出("=== 测试 3: 从模块导入函数 ===")
输出(平方根(25))

# --- 测试 4：从模块导入并起别名 ---
从 数学 导入 平方根 作为 开方
输出("=== 测试 4: 导入函数别名 ===")
输出(开方(36))

# --- 测试 5：导入多个模块 ---
导入 随机, 时间
输出("=== 测试 5: 多模块导入 ===")
输出(随机.randint(1, 10))
输出(时间.time())

# --- 测试 6：从模块导入所有 ---
从 数学 导入 所有
输出("=== 测试 6: 导入所有 ===")
输出(平方根(49))

# --- 测试 7：使用中文封装模块 (stdlib 目录下的模块) ---
导入 随机
输出("=== 测试 7: 中文封装模块 ===")
输出(随机.choice(["猫", "狗", "鸟"]))

# --- 测试 8：使用中文封装模块的类 ---
导入 日期时间
输出("=== 测试 8: 中文封装模块类 ===")
当前 = 日期时间.datetime.now()
输出(当前.year)

# --- 测试 9：组合导入 ---
从 数学 导入 pi, e
输出("=== 测试 9: 组合导入 ===")
输出(pi)
输出(e)

# --- 测试 10：使用导入的模块进行计算 ---
导入 数学
输出("=== 测试 10: 计算 ===")
半径 = 5
面积 = 数学.pi 乘 (半径 的次方 2)
输出(面积)

输出("所有测试通过!")
