# ============================================================
# Phase 5 测试：面向对象高级特性 + 生成器
# ============================================================

输出("=== Phase 5: 面向对象高级特性测试 ===")

# --- 测试 1: Property 属性装饰器 ---
输出("=== 测试 1: Property 属性装饰器 ===")

类 人员:
    属性:  # @property
        def 获取年龄:
            返回 self._年龄
        def 设置年龄:
            self._年龄 = 值

    定义 __init__(自身, 名字, 年龄):
        self._名字 = 名字
        self._年龄 = 年龄

    定义 获取名字:
        返回 self._名字

p = 人员("张三", 25)
输出(f"名字: {p.获取名字()}")
输出(f"年龄: {p.获取年龄()}")
p.设置年龄(30)
输出(f"设置年龄后: {p.获取年龄()}")

# --- 测试 2: Getter 和 Setter ---
输出("=== 测试 2: Getter 和 Setter ===")

类 银行账户:
    属性:  # @property
        def 获取余额:
            返回 self._余额
        def 设置余额:
            if 值 >= 0:
                self._余额 = 值
            否则:
                输出("错误: 余额不能为负数")

    定义 __init__(自身, 初始余额):
        self._余额 = 初始余额

acc = 银行账户(1000)
输出(f"初始余额: {acc.获取余额()}")
acc.设置余额(1500)
输出(f"存入后余额: {acc.获取余额()}")

# --- 测试 3: Classmethod ---
输出("=== 测试 3: Classmethod ===")

类 数学工具:
    类方法:  # @classmethod
        def 创建单位向量:
            返回 cls(1.0, 0.0, 0.0)

    定义 __init__(自身, x, y, z):
        self.x = x
        self.y = y
        self.z = z

    定义 点积:
        返回 self.x * 其他.x + self.y * 其他.y + self.z * 其他.z

vec = 数学工具.创建单位向量()
output = 数学工具(1, 2, 3)
输出(f"向量 x: {vec.x}")
输出(f"向量: {vec}")

# --- 测试 4: Staticmethod ---
输出("=== 测试 4: Staticmethod ===")

类 计算器:
    静态方法:  # @staticmethod
        def 加:
            返回 a + b

    静态方法:
        def 乘:
            返回 a * b

输出(f"3 + 5 = {计算器.加(3, 5)}")
输出(f"3 * 5 = {计算器.乘(3, 5)}")

# --- 测试 5: Generator (yield) ---
输出("=== 测试 5: Generator (yield) ===")

类 斐波那契数列:
    定义 生成:
        a, b = 0, 1
        当 True:
            产生 a
            a, b = b, a + b

fib = 斐波那契数列().生成()
输出("前 10 个斐波那契数:")
对于 i 在 范围(10) 执行
    输出(fib.下一个())

# --- 测试 6: Generator (yield from) ---
输出("=== 测试 6: Generator (yield from) ===")

类 层级生成器:
    定义 生成自身:
        产生 "根节点"
        产生 "第一层"
        产生 "第二层"
        产生 "第三层"

    定义 生成子树:
        产生 "子树 A"
        产生 "子树 B"
        yield from self.生成自身

tree = 层级生成器()
输出("层级生成器:")
对于 item 在 tree.生成子树 执行
    输出(item)

# --- 测试 7: Enumerate ---
输出("=== 测试 7: 枚举 ===")

列表 = ["苹果", "香蕉", "橙子", "葡萄"]

输出("列表索引:")
对于 index, 水果 在 枚举(列表) 执行
    输出(f"{index}: {水果}")

# --- 测试 8: 生成器表达式 ---
输出("=== 测试 8: 生成器表达式 ===")

平方数 = (x ** 2 for x in 范围(5))
输出("前 5 个平方数:")
对于 num in 平方数:
    输出(num)

# --- 测试 9: 类继承与多态 ---
输出("=== 测试 9: 类继承 ===")

类 动物:
    定义 喊叫:
        输出("动物叫")

类 狗(动物):
    定义 喊叫:
        输出("汪汪!")

类 猫(动物):
    定义 喊叫:
        输出("喵喵!")

狗 = 狗()
猫 = 猫()
狗.喊叫()
猫.喊叫()

输出("所有 Phase 5 测试通过!")
