# ============================================================
# Phase 4 测试：文件操作 + 中文异常类映射
# ============================================================

导入 文件操作

# --- 测试 1：写入并读取文件 ---
输出("=== 测试 1: 写入并读取文件 ===")
文件操作.写入文件("/tmp/test_zhpy.txt", "你好，中文Python！")
内容 = 文件操作.读取文件("/tmp/test_zhpy.txt")
输出(内容)

# --- 测试 2：追加文件 ---
输出("=== 测试 2: 追加文件 ===")
文件操作.追加文件("/tmp/test_zhpy.txt", "\n第二行内容")
内容2 = 文件操作.读取文件("/tmp/test_zhpy.txt")
输出(内容2)

# --- 测试 3：逐行读取 ---
输出("=== 测试 3: 逐行读取 ===")
行列表 = 文件操作.逐行读取("/tmp/test_zhpy.txt")
对于 行 在 行列表 执行
    输出(行.strip())

# --- 测试 4：文件存在检查 ---
输出("=== 测试 4: 文件存在检查 ===")
如果 文件操作.文件存在("/tmp/test_zhpy.txt")
    输出("文件存在")
否则
    输出("文件不存在")

# --- 测试 5：获取文件大小 ---
输出("=== 测试 5: 文件大小 ===")
大小 = 文件操作.获取文件大小("/tmp/test_zhpy.txt")
输出(大小)

# --- 测试 6：获取文件名和扩展名 ---
输出("=== 测试 6: 文件名和扩展名 ===")
输出(文件操作.获取文件名("/tmp/test_zhpy.txt"))
输出(文件操作.获取扩展名("/tmp/test_zhpy.txt"))

# --- 测试 7：获取当前目录 ---
输出("=== 测试 7: 当前目录 ===")
输出(文件操作.获取当前目录())

# --- 测试 8：拼接路径 ---
输出("=== 测试 8: 拼接路径 ===")
输出(文件操作.拼接路径("/tmp", "test", "file.txt"))

# --- 测试 9：中文异常类捕获 - 零除错误 ---
输出("=== 测试 9: 捕获零除错误 ===")
尝试
    x = 10 除以 0
捕获 零除错误
    输出("捕获到零除错误")

# --- 测试 10：中文异常类捕获 - 值错误 ---
输出("=== 测试 10: 捕获值错误 ===")
尝试
    整数("abc")
捕获 值错误
    输出("捕获到值错误")

# --- 测试 11：中文异常类捕获 - 文件未找到 ---
输出("=== 测试 11: 捕获文件未找到 ===")
尝试
    文件操作.读取文件("/tmp/不存在的文件.txt")
捕获 文件未找到
    输出("捕获到文件未找到")

# --- 测试 12：异常别名（作为 e） ---
输出("=== 测试 12: 异常别名 ===")
尝试
    整数("xyz")
捕获 值错误 作为 e
    输出(e)

# --- 测试 13：使用 当错误为 语法 ---
输出("=== 测试 13: 当错误为语法 ===")
尝试
    x = 10 除以 0
捕获 当错误为 零除错误 作为 err
    输出(err)

# --- 测试 14：捕获泛型错误 ---
输出("=== 测试 14: 捕获泛型错误 ===")
尝试
    x = 10 除以 0
捕获 错误
    输出("捕获到通用错误")

# --- 测试 15：类型错误 ---
输出("=== 测试 15: 捕获类型错误 ===")
尝试
    长度(42)
捕获 类型错误
    输出("捕获到类型错误")

# --- 测试 16：键错误 ---
输出("=== 测试 16: 捕获键错误 ===")
尝试
    d = {"a": 1}
    v = d["b"]
捕获 键错误
    输出("捕获到键错误")

# --- 测试 17：索引错误 ---
输出("=== 测试 17: 捕获索引错误 ===")
尝试
    lst = [1, 2, 3]
    v = lst[10]
捕获 索引错误
    输出("捕获到索引错误")

# 清理测试文件
文件操作.删除文件("/tmp/test_zhpy.txt")

输出("所有Phase 4测试通过!")
