# 扩展标准库测试：路径、集合工具、CSV、哈希

输出("=== 标准库扩展测试 ===")

导入 路径
导入 集合工具
导入 CSV模块
导入 哈希

p = 路径.路径对象("/tmp/zhpy_stdlib_demo.txt")
输出(p.名称)
输出(p.后缀)
输出(p.父目录.名称)

计数 = 集合工具.计数器(["苹果", "香蕉", "苹果"])
输出(计数["苹果"])

队列 = 集合工具.双端队列([1, 2])
队列.追加(3)
输出(列表(队列))

文本 = "名字,年龄\n张三,18\n李四,20\n"
行列表 = 列表(CSV模块.字典读取器(文本.分割行()))
输出(行列表[0]["名字"])
输出(行列表[1]["年龄"])

摘要 = 哈希.SHA256文本("abc")
输出(摘要)

输出("标准库扩展测试通过!")
