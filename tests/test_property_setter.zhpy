# 测试真正 @property.setter 中文语法

输出("=== Property Setter 测试 ===")

类 温度计:
    定义 __init__(自身, 初始温度):
        self._摄氏度 = 初始温度

    @property
    定义 摄氏度(自身):
        返回 self._摄氏度

    @摄氏度.setter
    定义 摄氏度(自身, 值):
        如果 值 小于 -273.15 则
            抛出 值错误("温度不能低于绝对零度")
        self._摄氏度 = 值

温度 = 温度计(20)
输出(温度.摄氏度)
温度.摄氏度 = 30
输出(温度.摄氏度)

尝试
    温度.摄氏度 = -300
捕获 值错误:
    输出("捕获到温度错误")

输出("Property Setter 测试通过!")
