# 边缘测试：Phase 5 高级语法回归

输出("=== 边缘测试 ===")

类 计数器:
    定义 __init__(自身, 初始值):
        self._值 = 初始值

    属性:
        def 获取值:
            返回 self._值

        def 设置值:
            如果 值 大于等于 0 则
                self._值 = 值
            否则:
                self._值 = 0

c = 计数器(5)
输出(c.获取值())
c.设置值(-10)
输出(c.获取值())
c.设置值(12)
输出(c.获取值())

类 工具:
    静态方法:
        def 加:
            返回 a + b

    类方法:
        def 名称:
            返回 cls.__name__

输出(工具.加(7, 8))
输出(工具.名称())

类 序列:
    定义 生成:
        产生 1
        产生 2

s = 序列()
对于 x 在 s.生成 执行
    输出(x)

输出("边缘测试通过!")
